# Google AI API Key (required for Gemini calls)
GOOGLE_API_KEY=your-gemini-api-key

# Google Cloud Project (required for deployment)
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Calendar Auth — pick ONE approach:

# Option A: OAuth file (local development — run `python -m schedule_analyst.auth` first)
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json

# Option B: OAuth token via env var (Cloud Run — paste contents of token.json)
# GOOGLE_CALENDAR_TOKEN_JSON='{"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}'

# Option C: Service account (Cloud Run / production — requires domain-wide delegation)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# CALENDAR_OWNER_EMAIL=your-email@gmail.com

# Google Calendar ID (defaults to hackathon demo calendar — NEVER "primary" on public URLs)
# Set this to target a specific calendar
# GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Server port (Cloud Run sets this automatically)
PORT=8080
