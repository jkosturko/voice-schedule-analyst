# Google AI API Key (required for Gemini calls)
GOOGLE_API_KEY=your-gemini-api-key

# Google Cloud Project (required for deployment)
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Calendar Auth — pick ONE approach:

# Option A: OAuth (local development — run `python -m schedule_analyst.auth` first)
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json

# Option B: Service account (Cloud Run / production)
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# CALENDAR_OWNER_EMAIL=your-email@gmail.com

# Server port (Cloud Run sets this automatically)
PORT=8080
